# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Raw downloaded artwork - too large for git (~4GB locally). Only optimized
# WebP is committed for non-Punk pieces. Punk SVGs are an explicit exception:
# images.ts routes Punks directly to /art/all/{contract}-{tokenId}.svg, so the
# 40 CryptoPunk SVGs (~850KB total) ship to make the Punks chapter render
# on a fresh clone.
/public/art/all/*
!/public/art/all/0xb47e3cd837ddf8e4c57f05d70ab865de6e193bbb-*.svg
/public/art/grifters/

# Claude tooling
/.flashback/
/.agents/skills-lock.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
