# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Artwork now lives on Filebase IPFS (served via the gateway). Only a small
# KEEP-SET stays in git: the 40 CryptoPunk SVGs, the curated crops / Asendorf
# screengrabs / physical-piece render referenced by images.ts, and the on-chain
# SVG pieces. The auto-pulled optimized/thumbs webp and raw masters are dead
# weight and are NOT committed. See scripts/prune-local-art.mjs.
/public/art/all/*
!/public/art/all/0xb47e3cd837ddf8e4c57f05d70ab865de6e193bbb-*.svg
/public/art/grifters/
/public/art/optimized/*
!/public/art/optimized/curated-*.webp
!/public/art/optimized/operator-x-ray-machine.webp
/public/art/thumbs/*
!/public/art/thumbs/curated-*.webp
!/public/art/thumbs/operator-x-ray-machine.webp

# Claude tooling
/.flashback/
/.agents/skills-lock.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code frameworks (exclude all)
.claude/
