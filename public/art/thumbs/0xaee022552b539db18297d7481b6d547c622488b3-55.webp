<svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 100 100"><style>:root {--c0:rgb(248,122,169);--c1:rgb(138,113,197);--c2:rgb(216,55,115);--c3:rgb(27,21,40);}</style><defs><text id="token">55</text><text id="pixels">1000000</text><rect id="frame" width="2" height="100"><animate attributeName="fill" dur="2s" keyTimes="0;0.25;0.5;0.75;1" values="rgb(248,122,169);rgb(138,113,197);rgb(216,55,115);rgb(27,21,40);rgb(248,122,169);" repeatCount="indefinite"/></rect></defs><style>svg{width:100%;height:100%;background-color:#000;}.txt{font-family:"Lucida Grande","Lucida Sans","Lucida Sans Regular","Lucida Sans Unicode",Geneva,Verdana,sans-serif;font-size:3px;fill:#fff;}</style><defs><linearGradient id="g0" gradientTransform="rotate(90)"><stop stop-color="var(--c0)" offset="0%"/><stop stop-color="var(--c2)" offset="100%"/></linearGradient><linearGradient id="g1" gradientTransform="rotate(90)"><stop stop-color="var(--c1)" offset="0%"/><stop stop-color="var(--c3)" offset="100%"/></linearGradient></defs><use xlink:href="#frame" x="0" y="0"/><path d="M44 46 L44 54 A6 3 0 0 0 56 54 L56 46Z" fill="url(#g0)"/><ellipse cx="50" cy="46" rx="6" ry="3" fill="url(#g1)"/><text class="txt" x="49.5" y="12" text-anchor="end">Pod</text><use href="#token" class="txt" x="50.5" y="12"/><use href="#pixels" class="txt" x="49.5" y="90" text-anchor="end"/><text class="txt" x="50.5" y="90">PXL</text></svg>