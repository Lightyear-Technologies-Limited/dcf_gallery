# DCF Gallery — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit secrets.
# These are used by the data/asset pipeline scripts (not shipped to the browser).

# ---- Ethereum RPC + NFT metadata (Alchemy recommended) ----------------------
# Resolves on-chain tokenURI, NFT metadata, traits, and animation_url (for the
# animated/video pieces). One Alchemy key covers JSON-RPC + the NFT API.
ALCHEMY_API_KEY=
# Alternatively, a generic mainnet RPC URL if you'd rather not use Alchemy:
ETH_RPC_URL=

# ---- Filebase (IPFS bucket: storage + pinning + gateway) --------------------
# S3-compatible credentials from the Filebase console for the IPFS bucket.
# Used to upload/pin canonical originals and read back the CID.
FILEBASE_ACCESS_KEY=
FILEBASE_SECRET_KEY=
FILEBASE_BUCKET=
# S3-compatible endpoint for an IPFS bucket (per Filebase docs):
FILEBASE_S3_ENDPOINT=https://s3.filebase.com
# Your dedicated IPFS gateway host (serves pinned CIDs + on-the-fly image opt):
FILEBASE_GATEWAY=lightyear.myfilebase.com

# ---- Site URL (OG/share metadata; metadataBase) -----------------------------
# Public site origin used to resolve relative OG/canonical URLs. Set to the
# final domain when known (Vercel also exposes VERCEL_URL automatically).
NEXT_PUBLIC_SITE_URL=https://gallery.hivemind.capital

# ---- Optional: richer NFT metadata fallback ---------------------------------
# Only if some collections need OpenSea/Reservoir to resolve animation_url or
# metadata that Alchemy doesn't return. Leave blank unless a gap appears.
# OPENSEA_API_KEY=
# RESERVOIR_API_KEY=
